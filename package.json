    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "schema-dts": "^1.1.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.4",
    "prettier": "^3.6.0",
